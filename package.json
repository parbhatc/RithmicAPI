{
  "name": "rithmic-api",
  "version": "1.0.0",
  "description": "Unofficial Node.js client for the Rithmic Protocol Buffer WebSocket API",
  "type": "module",
  "main": "./index.js",
  "exports": "./index.js",
  "files": [
    "index.js",
    "lib",
    "protocol",
    "proto"
  ],
  "scripts": {
    "example:discover": "node --env-file=.env examples/discover.mjs",
    "example:history": "node --env-file=.env examples/chartHistory.mjs",
    "example:live": "node --env-file=.env examples/chartLive.mjs",
    "example:tick": "node --env-file=.env examples/chartTickHistory.mjs",
    "example:fetch": "node --env-file=.env examples/historyFetch.mjs",
    "example:order": "node --env-file=.env examples/orderSession.mjs",
    "example:pnl": "node --env-file=.env examples/pnlSession.mjs",
    "test:compare-1m": "node --env-file=.env testing/tradesea/compare-1m-history.mjs",
    "test:compare-history": "node --env-file=.env testing/tradesea/compare-history.mjs",
    "test": "node --env-file=.env examples/discover.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "rithmic",
    "trading",
    "websocket",
    "protobuf",
    "futures"
  ],
  "license": "MIT",
  "dependencies": {
    "protobufjs": "^7.4.0",
    "ws": "^8.18.0"
  }
}
